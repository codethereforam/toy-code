#lang racket
; continuation 入门 03: shift/reset（白话版）
; --------------------------------------------------------
; 运行本文件需要 Racket：
(require racket/control)

; 一句话先记住：
; - call/cc 像“整层楼总电闸”
; - shift/reset 像“当前房间开关”
;
; 为什么说 shift/reset 更好入门？
; 因为它只影响 reset 包起来的这一小段代码，范围更可控。

; --------------------------------------------------------
; 例子 1：k 是“把值塞回洞里”的函数
; --------------------------------------------------------
; 这段里，shift 把 (+ 1 [洞]) 抓出来命名为 k。
; 所以 (k 10) 就是 (+ 1 10) => 11
(define ex1
  (reset
    (+ 1
       (shift k
         (k 10)))))

(displayln (format "ex1 => ~a" ex1)) ; 11

; --------------------------------------------------------
; 例子 2：同一个 k 可以调用多次
; --------------------------------------------------------
; 这里 k 仍然表示 (+ 1 [洞])。
; - (k 10) => 11
; - (k 20) => 21
; shift 里把两个结果相加 => 32
(define ex2
  (reset
    (+ 1
       (shift k
         (+ (k 10)
            (k 20))))))

(displayln (format "ex2 => ~a" ex2)) ; 32

; --------------------------------------------------------
; 例子 3：把 k 当成“后续流程”
; --------------------------------------------------------
; reset 外层是 (* 2 [洞])，所以 k(v) 就是 (* 2 v)。
; 我们分别调用：
; - (k x)
; - (k (+ x 10))
; 然后把两次结果相加。
(define (demo-pipeline x)
  (reset
    (* 2
       (shift k
         (define a (k x))
         (define b (k (+ x 10)))
         (+ a b)))))

(displayln (format "demo-pipeline 5 => ~a" (demo-pipeline 5)))

; 手算 demo-pipeline 5：
; a = (k 5)  = (* 2 5)  = 10
; b = (k 15) = (* 2 15) = 30
; a + b = 40
